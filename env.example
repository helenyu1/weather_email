# SMTP 配置
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USE_SSL=true
SMTP_USER=sender@example.com
SMTP_PASSWORD=your_email_authorization_code

# 多个收件人用英文逗号分隔
WEATHER_EMAIL_TO=receiver@example.com

# 可选：法定节假日/调休工作日，用于覆盖普通周一到周五逻辑
# 格式：YYYY-MM-DD,YYYY-MM-DD
WEATHER_EMAIL_HOLIDAYS=
WEATHER_EMAIL_EXTRA_WORKDAYS=
